{
  "name": "vidit",
  "private": true,
  "version": "0.1.0",
  "description": "Vidit — desktop video editor",
  "author": "Vidit",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && electron-builder",
    "build:dir": "tsc -b && vite build && electron-builder --dir",
    "build:app": "tsc -b && vite build",
    "fixtures": "node scripts/make-fixtures.mjs",
    "postinstall": "node scripts/fix-electron.mjs",
    "test:e2e": "npm run build:app && npm run fixtures && playwright test",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "immer": "^11.1.11",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "uuid": "^14.0.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.1",
    "electron": "^39.8.10",
    "electron-builder": "^26.8.1",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.vidit.editor",
    "productName": "Vidit",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**",
      "**/node_modules/ffprobe-static/**"
    ],
    "extraResources": [],
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
